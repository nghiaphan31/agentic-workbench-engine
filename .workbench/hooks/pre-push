#!/bin/sh
# pre-push hook — The Arbiter's Push Gate
#
# Owner: The Arbiter (Layer 2b)
# Version: 2.1
# Location: .workbench/hooks/pre-push
#
# This hook runs BEFORE any git push is completed.
# It enforces:
#   1. Blocking states: RED, REGRESSION_RED, INTEGRATION_RED, PIVOT_IN_PROGRESS
#   2. Direct push to main is blocked (merges only)
#
# Exit codes:
#   0 = push allowed
#   1 = push blocked

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "[PRE-PUSH] Running Arbiter push gate checks..."

# =============================================================================
# 1. CHECK FOR BLOCKING STATES
# =============================================================================
BLOCKING_STATES="RED REGRESSION_RED INTEGRATION_RED PIVOT_IN_PROGRESS"

if [ -f "state.json" ]; then
    CURRENT_STATE=$(python -c "import json; s=json.load(open('state.json')); print(s.get('state',''))" 2>/dev/null || echo "UNKNOWN")
    
    for blocking_state in $BLOCKING_STATES; do
        if [ "$CURRENT_STATE" = "$blocking_state" ]; then
            echo "[PRE-PUSH] ${RED}BLOCKED: Cannot push while state is $blocking_state${NC}"
            echo "  Current state: $CURRENT_STATE"
            echo "  Complete the current pipeline stage before pushing."
            echo "  Run: python .workbench/scripts/test_orchestrator.py run --scope full --set-state"
            exit 1
        fi
    done
fi

# =============================================================================
# 1b. CHECK FOR DELETED SOURCE BRANCH IN MERGE COMMITS (CMT-2)
# =============================================================================
# git merge --delete-branch removes the source branch after merge — this is forbidden
# Detect if this push contains a merge to main/develop and warn the user
if [ "$branch" = "main" ] || [ "$branch" = "develop" ]; then
    merge_base=$(git merge-base "$oldrev" "$newrev" 2>/dev/null || echo "")
    if [ -n "$merge_base" ] && [ "$merge_base" != "$oldrev" ]; then
        echo "[PRE-PUSH] ${YELLOW}WARNING: Merge detected to $branch${NC}"
        echo "  Ensure --delete-branch was NOT used when creating this merge."
        echo "  Use: git merge --no-delete-branch (CMT-2)"
    fi
fi

# =============================================================================
# 2. CHECK FOR DIRECT PUSH TO MAIN (non-merge commits only)
# =============================================================================
# Get the remote and branch being pushed
remote="$1"
url="$2"

# Get the list of commits being pushed
z40='0000000000000000000000000000000000000000'

while IFS= read -r oldrev newrev refname; do
    branch=$(echo "$refname" | sed 's|refs/heads/||')
    
    # Skip tag pushes
    if [ "$branch" = "" ]; then
        continue
    fi
    
    # Check if this is a direct push to main/develop (not a merge)
    BLOCKED_BRANCHES="main master develop"
    if echo "$BLOCKED_BRANCHES" | grep -w "$branch" > /dev/null; then
        # Check if this is a fast-forward push or a force push
        # A merge commit would have two parents
        if [ "$oldrev" != "$z40" ]; then
            # Not a new branch - check if it's a merge
            parent_count=$(git rev-list --parents --count "$newrev" ^"$oldrev" 2>/dev/null | tr -d ' ')
            if [ "$parent_count" -lt 2 ]; then
                # Not a merge commit - check for APPROVED-BY-HUMAN exception
                if [ "$branch" = "develop" ]; then
                    # Check if trivial chore commit with human approval
                    commit_message=$(git log -1 --format="%s" "$newrev" 2>/dev/null || echo "")
                    # GAP-6 FIX: APPROVED-BY-HUMAN must be in footer as proper token
                    # Valid: "chore: fix typo\nAPPROVED-BY-HUMAN" (footer token on own line)
                    # Invalid: "feat: add feature\nThis needs APPROVED-BY-HUMAN later"
                    # Check that APPROVED-BY-HUMAN appears in the last 2 lines (footer context)
                    if echo "$commit_message" | tail -2 | grep -qE "APPROVED-BY-HUMAN"; then
                        # Verify it's a trivial chore (type=chore)
                        if echo "$commit_message" | grep -qE "^chore(\([^\)]+\))?:.*"; then
                            echo "[PRE-PUSH] ${YELLOW}WARNING: Approved trivial chore to develop${NC}"
                            echo "  Branch: $branch"
                            echo "  Commit: $commit_message"
                            echo "  Push allowed with human approval."
                        else
                            echo "[PRE-PUSH] ${RED}BLOCKED: APPROVED-BY-HUMAN requires chore type${NC}"
                            echo "  Commit type must be 'chore', not feat/fix/docs/etc."
                            exit 1
                        fi
                    else
                        echo "[PRE-PUSH] ${RED}BLOCKED: APPROVED-BY-HUMAN must be in commit footer as proper token${NC}"
                        echo "  Format: chore: <description>\nAPPROVED-BY-HUMAN"
                        echo "  APPROVED-BY-HUMAN must appear on its own line at the end."
                        exit 1
                    fi
                else
                    # main/master - no exception
                    echo "[PRE-PUSH] ${RED}BLOCKED: Direct push to $branch is not allowed${NC}"
                    echo "  Branch: $branch"
                    echo "  Only merge commits via PR are allowed for $branch."
                    echo "  Push to a feature branch and create a Pull Request instead."
                    exit 1
                fi
            fi
        fi
    fi
done

# =============================================================================
# 3. CHECK REGRESSION STATE
# =============================================================================
if [ -f "state.json" ]; then
    REGRESSION_STATE=$(python -c "import json; s=json.load(open('state.json')); print(s.get('regression_state',''))" 2>/dev/null || echo "UNKNOWN")
    if [ "$REGRESSION_STATE" = "REGRESSION_RED" ]; then
        echo "[PRE-PUSH] ${RED}BLOCKED: Regression detected${NC}"
        echo "  regression_state: $REGRESSION_STATE"
        echo "  Fix regressions before pushing."
        echo "  Run: python .workbench/scripts/test_orchestrator.py run --scope full --set-state"
        exit 1
    fi
fi

# =============================================================================
# FOR-1(4): CHECK PHASE 2 EVIDENCE SEAL
# =============================================================================
# Feature branches merging to develop/main must have Phase 2 evidence seal
# This enforces that full regression was run before merge

# Check if pushing to develop or main
if [ "$branch" = "develop" ] || [ "$branch" = "main" ]; then
    # Get the current commit hash
    CURRENT_COMMIT=$(git rev-parse --verify HEAD 2>/dev/null || echo "")
    
    if [ -n "$CURRENT_COMMIT" ]; then
        # Check if seal exists for this commit
        SEAL_FILE=".workbench/test_evidence/seals/${CURRENT_COMMIT}.seal"
        
        if [ -f "$SEAL_FILE" ]; then
            # Verify Phase 2 was passed
            PHASE2_PASSED=$(python -c "import json; s=json.load(open('$SEAL_FILE')); print(s.get('phase2_passed', False))" 2>/dev/null || echo "False")
            
            if [ "$PHASE2_PASSED" = "True" ]; then
                echo "[PRE-PUSH] ${GREEN}FOR-1(4): Phase 2 evidence seal verified${NC}"
            else
                echo "[PRE-PUSH] ${RED}BLOCKED: Phase 2 seal exists but Phase 2 did not pass${NC}"
                echo "  Commit: $CURRENT_COMMIT"
                echo "  Run: python .workbench/scripts/test_orchestrator.py run --scope full --set-state"
                exit 1
            fi
        else
            echo "[PRE-PUSH] ${RED}BLOCKED: No Phase 2 evidence seal found${NC}"
            echo "  Commit: $CURRENT_COMMIT"
            echo "  FOR-1(4): Feature branch merge requires Phase 2 full regression evidence"
            echo "  Run: python .workbench/scripts/test_orchestrator.py run --scope full --set-state"
            exit 1
        fi
    fi
fi

# =============================================================================
# FOR-1(1): CHECK CSTA STATE TRANSITION SIGNATURE
# =============================================================================
# Feature branches merging to develop/main must have Arbiter-signed state transition
# This enforces that only the Arbiter (test_orchestrator) can sign state transitions
# Agents cannot self-transition state to GREEN

# Check if pushing to develop or main
if [ "$branch" = "develop" ] || [ "$branch" = "main" ]; then
    if [ -f "state.json" ]; then
        CURRENT_STATE=$(python -c "import json; s=json.load(open('state.json')); print(s.get('state',''))" 2>/dev/null || echo "")
        ACTIVE_REQ=$(python -c "import json; s=json.load(open('state.json')); print(s.get('active_req_id',''))" 2>/dev/null || echo "")
        
        if [ "$CURRENT_STATE" = "GREEN" ] || [ "$CURRENT_STATE" = "MERGED" ]; then
            if [ -n "$ACTIVE_REQ" ]; then
                # Look for CSTA signature file
                TRANSITION_SIG=$(ls ".workbench/test_evidence/transitions/${ACTIVE_REQ}"_*_"${CURRENT_STATE}.sig" 2>/dev/null || echo "")
                
                if [ -f "$TRANSITION_SIG" ]; then
                    # Verify signature is from Arbiter
                    SIG_KEY_ID=$(python -c "import json; s=json.load(open('$TRANSITION_SIG')); print(s.get('arbiter_key_id',''))" 2>/dev/null || echo "")
                    
                    if echo "$SIG_KEY_ID" | grep -qi "arbiter"; then
                        echo "[PRE-PUSH] ${GREEN}FOR-1(1): CSTA state transition signature verified${NC}"
                    else
                        echo "[PRE-PUSH] ${RED}BLOCKED: State transition signature is not from Arbiter${NC}"
                        echo "  Signature key ID: $SIG_KEY_ID"
                        echo "  FOR-1(1): Only test_orchestrator.py (Arbiter) may sign state transitions"
                        echo "  Agent self-transition is forbidden."
                        exit 1
                    fi
                else
                    echo "[PRE-PUSH] ${RED}BLOCKED: No CSTA state transition signature found${NC}"
                    echo "  Active REQ: $ACTIVE_REQ"
                    echo "  State: $CURRENT_STATE"
                    echo "  FOR-1(1): Feature branch merge requires Arbiter-signed state transition"
                    echo "  Run: python .workbench/scripts/test_orchestrator.py run --scope full --set-state"
                    exit 1
                fi
            fi
        fi
    fi
fi

# =============================================================================
# PVT-2: CHECK PIVOT BRANCH CMS SIGNATURE
# =============================================================================
# For pivot/* branches, verify that an Architect signature exists in git notes
# This enforces that only Architect Agent may initiate pivot branches (PVT-2)
# 
# Git note format for pivot signature:
#   git notes --ref=pivot-signature add -m 'architect:<base64_signature>' HEAD

# Check if this is a pivot branch being pushed
if echo "$branch" | grep -q "^pivot/"; then
    # Get the pivot ticket ID from state.json
    if [ -f "state.json" ]; then
        PIVOT_TICKET=$(python -c "import json; s=json.load(open('state.json')); print(s.get('active_req_id',''))" 2>/dev/null || echo "")
        
        # Try to extract ticket ID from branch name if not in state
        if [ -z "$PIVOT_TICKET" ]; then
            # Extract REQ-NNN from branch name (e.g., pivot/REQ-042-fix -> REQ-042)
            PIVOT_TICKET=$(echo "$branch" | grep -oE "REQ-[0-9]+" | head -1 || echo "UNKNOWN")
        fi
        
        # Get signature from git note
        # Note: refs/notes/pivot-signature on the branch being pushed
        SIGNATURE_NOTE=$(git notes --ref=pivot-signature show "refs/heads/${branch}" 2>/dev/null || echo "")
        
        if [ -z "$SIGNATURE_NOTE" ]; then
            echo "[PRE-PUSH] ${RED}BLOCKED: No Architect signature found for pivot branch${NC}"
            echo "  Branch: $branch"
            echo "  PVT-2: Only Architect Agent may create pivot branches"
            echo "  To sign a pivot: python .workbench/scripts/mode_keys.py sign architect $PIVOT_TICKET $branch"
            echo "  Then add note: git notes --ref=pivot-signature add -m 'architect:<signature>' HEAD"
            exit 1
        fi
        
        # Parse signature from note (expected: 'architect:<base64_signature>')
        if ! echo "$SIGNATURE_NOTE" | grep -q "^architect:"; then
            echo "[PRE-PUSH] ${RED}BLOCKED: Invalid pivot signature format${NC}"
            echo "  Branch: $branch"
            echo "  Note format must be: architect:<base64_signature>"
            exit 1
        fi
        
        SIGNATURE=$(echo "$SIGNATURE_NOTE" | sed 's/^architect://' | tr -d ' \n')
        
        # Verify signature using mode_keys.py
        VERIFY_RESULT=$(python ".workbench/scripts/mode_keys.py" verify architect "$PIVOT_TICKET" "$branch" "$SIGNATURE" 2>/dev/null || echo "VERIFY_FAILED")
        
        if echo "$VERIFY_RESULT" | grep -q "VERIFIED"; then
            echo "[PRE-PUSH] ${GREEN}PVT-2: Pivot branch Architect signature verified${NC}"
        else
            echo "[PRE-PUSH] ${RED}BLOCKED: Pivot branch signature invalid or tampered${NC}"
            echo "  Branch: $branch"
            echo "  Ticket: $PIVOT_TICKET"
            echo "  PVT-2: Only Architect Agent may create pivot branches"
            echo "  Signature verification failed."
            exit 1
        fi
    else
        echo "[PRE-PUSH] ${RED}BLOCKED: Cannot verify pivot signature without state.json${NC}"
        exit 1
    fi
fi

# =============================================================================
# ALL CHECKS PASSED
# =============================================================================
echo "[PRE-PUSH] ${GREEN}All push gate checks passed — push allowed${NC}"
exit 0
